# Get a free PostgreSQL database at https://neon.tech
# Use the "pooled" connection string for DATABASE_URL
DATABASE_URL="postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require"
# Use the "direct" (non-pooled) connection string for DIRECT_URL
DIRECT_URL="postgresql://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require"

# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Only needed for local dev, Vercel sets this automatically
NEXTAUTH_URL="http://localhost:3000"

# Optional: CricAPI key for live scores (https://cricapi.com)
CRICKET_API_KEY=""
